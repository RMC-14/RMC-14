<controls:RequisitionsPendingOrderCard
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Requisitions"
    xmlns:ui="clr-namespace:Content.Client._RMC14.UserInterface"
    Orientation="Vertical"
    HorizontalExpand="True">
    <PanelContainer HorizontalExpand="True">
        <BoxContainer Orientation="Horizontal" Margin="6" HorizontalExpand="True">
            <LayeredTextureRect Name="Icon"
                                Access="Public"
                                SetSize="64 64"
                                Stretch="KeepAspectCentered"
                                RectClipContent="True" />
            <Control MinWidth="8" />
            <BoxContainer Orientation="Vertical"
                          HorizontalExpand="True"
                          VerticalAlignment="Top">
                <RichTextLabel Name="ProductName"
                               Access="Public"
                               HorizontalExpand="True"
                               VerticalAlignment="Top" />
                <RichTextLabel Name="Description"
                               Access="Public"
                               HorizontalExpand="True"
                               VerticalAlignment="Top" />
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                    <Label Name="Cost" Access="Public" />
                    <Control HorizontalExpand="True" />
                    <Label Name="Quantity"
                           Access="Public"
                           Align="Right"
                           MinWidth="120" />
                </BoxContainer>
            </BoxContainer>
        </BoxContainer>
    </PanelContainer>
    <ui:BlueHorizontalSeparator />
</controls:RequisitionsPendingOrderCard>
