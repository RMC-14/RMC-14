<controls:RequisitionsBlackMarketHome
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Requisitions"
    HorizontalExpand="True">
    <BoxContainer Orientation="Vertical"
                  HorizontalExpand="True"
                  Margin="8">
        <BoxContainer Orientation="Horizontal"
                      HorizontalExpand="True"
                      Margin="0 0 0 8">
            <Label Name="ContactLabel"
                   Access="Public"
                   Text="{Loc rmc-requisitions-black-market-contact}"
                   HorizontalExpand="True" />
            <RichTextLabel Name="BalanceLabel"
                           Access="Public"
                           HorizontalAlignment="Right" />
        </BoxContainer>
        <PanelContainer Name="DialoguePanel"
                        Access="Public"
                        HorizontalExpand="True"
                        Margin="0 0 0 8">
            <BoxContainer Name="DialogueContents"
                          Access="Public"
                          Orientation="Vertical"
                          HorizontalExpand="True"
                          Margin="8" />
        </PanelContainer>
        <Button Name="BriefingButton"
                Access="Public"
                StyleClasses="ButtonSquare"
                HorizontalExpand="False"
                MinWidth="120"
                Margin="0 0 0 8" />
        <Label Name="CategoriesTitle"
               Access="Public"
               Text="{Loc rmc-requisitions-black-market-categories-title}"
               Margin="0 0 0 4" />
        <BoxContainer Name="CategoryButtons"
                      Access="Public"
                      Orientation="Vertical"
                      HorizontalExpand="True" />
    </BoxContainer>
</controls:RequisitionsBlackMarketHome>
