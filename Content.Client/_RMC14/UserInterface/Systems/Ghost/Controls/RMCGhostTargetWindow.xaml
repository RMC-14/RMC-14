<controls:RMCGhostTargetWindow xmlns="https://spacestation14.io"
             xmlns:controls="clr-namespace:Content.Client._RMC14.UserInterface.Systems.Ghost.Controls"
             xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
             xmlns:xaml="clr-namespace:Robust.Client.UserInterface.XAML;assembly=Robust.Client"
             Title="{Loc 'ghost-target-window-title'}" MinSize="500 450" SetSize="500 550">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" SizeFlagsStretchRatio="0.4">
        <PanelContainer HorizontalExpand="True" Margin="0 0 0 4">
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat
                    BorderThickness="0"
                    BackgroundColor="#00000054" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="6">
                <TextureRect TexturePath="/Textures/_RMC14/Interface/search.svg.96dpi.png"
                             SetSize="18 18"
                             Stretch="KeepAspectCentered"
                             VerticalAlignment="Center"
                             Margin="0 0 6 0" />
                <LineEdit Name="SearchBar"
                          StyleClasses="actionSearchBox"
                          PlaceHolder="{Loc 'rmc-ghost-target-window-search-placeholde'}"
                          HorizontalExpand="True"
                          VerticalAlignment="Center">
                    <LineEdit.StyleBoxOverride>
                        <graphics:StyleBoxTexture
                            Texture="{xaml:UiTex '/Textures/Interface/Nano/rounded_button_bordered.svg.96dpi.png'}"
                            Modulate="#101010"
                            PatchMarginTop="5"
                            PatchMarginBottom="5"
                            PatchMarginLeft="5"
                            PatchMarginRight="5"
                            ContentMarginTopOverride="3"
                            ContentMarginBottomOverride="3"
                            ContentMarginLeftOverride="6"
                            ContentMarginRightOverride="6" />
                    </LineEdit.StyleBoxOverride>
                </LineEdit>
                <PanelContainer SetWidth="2" VerticalExpand="True" Margin="8 0 6 0">
                    <PanelContainer.PanelOverride>
                        <graphics:StyleBoxFlat
                            BorderThickness="0"
                            BackgroundColor="#FFFFFF1A" />
                    </PanelContainer.PanelOverride>
                </PanelContainer>
                <Button Name="GhostnadoButton"
                        SetSize="40 26"
                        ToolTip="{Loc 'ghost-target-window-warp-to-most-followed'}"
                        Margin="0 0 4 0">
                    <Button.StyleBoxOverride>
                        <graphics:StyleBoxTexture
                            Texture="{xaml:UiTex '/Textures/Interface/Nano/rounded_button.svg.96dpi.png'}"
                            Modulate="#5BAA27"
                            PatchMarginTop="5"
                            PatchMarginBottom="5"
                            PatchMarginLeft="5"
                            PatchMarginRight="5"
                            ContentMarginLeftOverride="6"
                            ContentMarginRightOverride="6" />
                    </Button.StyleBoxOverride>
                    <TextureRect TexturePath="/Textures/Interface/NavMap/beveled_star.png"
                                 SetSize="17 17"
                                 Stretch="KeepAspectCentered"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center" />
                </Button>
                <Button Name="RefreshButton"
                        SetSize="28 26"
                        ToolTip="{Loc 'rmc-ghost-target-window-refresh'}">
                    <Button.StyleBoxOverride>
                        <graphics:StyleBoxEmpty />
                    </Button.StyleBoxOverride>
                    <TextureRect TexturePath="/Textures/Interface/VerbIcons/refresh.svg.192dpi.png"
                                 SetSize="17 17"
                                 Stretch="KeepAspectCentered"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 ModulateSelfOverride="#8C8C8C" />
                </Button>
            </BoxContainer>
        </PanelContainer>
        <PanelContainer VerticalExpand="True" HorizontalExpand="True">
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat
                    BorderThickness="0"
                    BackgroundColor="#00000054" />
            </PanelContainer.PanelOverride>
            <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True" Margin="6">
                <ScrollContainer Name="GhostScroll" VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="ContentContainer" Orientation="Vertical" VerticalExpand="True" SeparationOverride="5">
                        <!-- Target buttons get added here by code -->
                    </BoxContainer>
                </ScrollContainer>
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</controls:RMCGhostTargetWindow>
