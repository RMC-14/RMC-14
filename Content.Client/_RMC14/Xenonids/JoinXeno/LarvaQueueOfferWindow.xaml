<cc:LarvaQueueOfferWindow
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client._RMC14.Xenonids.JoinXeno"
    Title="Larva Spawn Offer"
    MinSize="360 220">
    <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="8">
        <Label Name="OfferTypeLabel" Access="Public" HorizontalAlignment="Center" StyleClasses="LabelBig" />
        <Label Name="PositionLabel" Access="Public" HorizontalAlignment="Center" />
        <Label Name="HiveLabel" Access="Public" HorizontalAlignment="Center" />
        <Label Name="CountdownLabel" Access="Public" HorizontalAlignment="Center" />
        <Control VerticalExpand="True" />
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="8" Margin="0 4 0 0">
            <Button Name="AcceptButton" Access="Public" MinHeight="35" HorizontalExpand="True"
                    Text="Accept" StyleClasses="ButtonColorGreen" />
            <Button Name="FollowButton" Access="Public" MinHeight="35" HorizontalExpand="True"
                    Text="Follow" />
            <Button Name="DeclineButton" Access="Public" MinHeight="35" HorizontalExpand="True"
                    Text="Decline" StyleClasses="ButtonColorDefaultRed" />
        </BoxContainer>
    </BoxContainer>
</cc:LarvaQueueOfferWindow>
