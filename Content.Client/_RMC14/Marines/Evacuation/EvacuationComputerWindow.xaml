<controls:EvacuationComputerWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Marines.Evacuation"
    xmlns:ui="clr-namespace:Content.Client._RMC14.UserInterface"
    Title="Escape Pod Controller">
    <BoxContainer Orientation="Vertical">
        <RichTextLabel Text="{Loc rmc-evac-comp-information-display}" />
        <ui:BlueHorizontalSeparator />
        <Label Name="StatusLabel" Access="Public" Text="{Loc rmc-evac-comp-status-label}" />
        <Label Name="HatchLabel" Access="Public" Text="{Loc rmc-evac-comp-hatch-label}" />
        <RichTextLabel Text="[bold]Pod controls[/bold]" Margin="0 10 0 0" />
        <ui:BlueHorizontalSeparator />
        <Button Name="DoorButton" Access="Public" Text="{Loc rmc-evac-comp-door-button-unlock}" StyleClasses="OpenBoth" />
        <Button Name="EjectButton" Access="Public" Text="{Loc rmc-evac-comp-eject-button-manual}" StyleClasses="OpenBoth" />
        <Button Name="DelayButton" Access="Public" Text="{Loc rmc-evac-comp-delay-button}" StyleClasses="OpenBoth" />
    </BoxContainer>
</controls:EvacuationComputerWindow>
