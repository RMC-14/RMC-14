<controls:CommandTabletActionButton
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Marines.CommandTablet">
    <controls:CommandTabletScanlinePanel Name="Background" Access="Public"
                                         HorizontalExpand="True" VerticalExpand="True" MouseFilter="Ignore">
        <BoxContainer Name="Layout" Access="Public" Orientation="Horizontal" Align="Begin"
                      HorizontalAlignment="Stretch" HorizontalExpand="True"
                      SeparationOverride="5" Margin="8 2 4 2" MouseFilter="Ignore">
            <TextureRect Name="IconControl" Access="Public"
                         SetWidth="16" SetHeight="16" Stretch="Scale"
                         HorizontalExpand="False"
                         HorizontalAlignment="Left" VerticalAlignment="Center"
                         MouseFilter="Ignore" />
            <Label Name="TextLabel" Access="Public" StyleClasses="LabelKeyText"
                   HorizontalExpand="False"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   MouseFilter="Ignore" />
        </BoxContainer>
    </controls:CommandTabletScanlinePanel>
</controls:CommandTabletActionButton>
