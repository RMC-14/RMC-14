<controls:CommandTabletWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RMC14.Marines.CommandTablet"
    xmlns:crt="clr-namespace:Content.Client._RMC14.UserInterface.Crt"
    Title="{Loc rmc-command-tablet-title}"
    MinSize="400 350"
    SetSize="400 350">
    <crt:RMCCrtThemeScope Palette="Custom" Effects="HorizontalScanlines"
                          CustomForeground="#FFFFFF" CustomBackground="#111314"
                          CustomBorder="#668DB8" CustomFill="#456B96" CustomFillForeground="#FFFFFF"
                          CustomMuted="#8B8D90" CustomWarning="#D46B22"
                          CustomDisabledBackground="#8B8D90" CustomDisabledForeground="#E6E6E6"
                          BorderThickness="1">
        <BoxContainer Orientation="Vertical" Margin="6" SeparationOverride="3"
                      HorizontalExpand="True" VerticalExpand="True">
            <crt:RMCCrtLabel Text="{Loc rmc-command-tablet-command}" Heading="True" />
            <crt:RMCCrtSeparator MinHeight="2" Margin="0 0 0 2" />
            <crt:RMCCrtActionButton Name="AnnouncementButton" Access="Public"
                Text="{Loc rmc-command-tablet-make-announcement}" IconState="bullhorn"
                Variant="Filled" ContentAlignment="Left" MinHeight="29" />
            <crt:RMCCrtActionButton Name="MedalButton" Access="Public"
                Text="{Loc rmc-command-tablet-give-medal}" IconState="medal"
                Variant="Filled" ContentAlignment="Left" MinHeight="29" />
            <crt:RMCCrtActionButton Name="TacticalMapButton" Access="Public"
                Text="{Loc rmc-command-tablet-view-tactical-map}" IconState="map"
                Variant="Filled" ContentAlignment="Left" MinHeight="29" />

            <BoxContainer Name="EvacuationSection" Access="Public"
                          Orientation="Vertical" SeparationOverride="3" Margin="0 4 0 0">
                <crt:RMCCrtLabel Text="{Loc rmc-command-tablet-evacuation}" Heading="True" />
                <crt:RMCCrtSeparator MinHeight="2" Margin="0 0 0 2" />
                <crt:RMCCrtPanel Name="EvacuationWarning" Access="Public" MinHeight="48"
                                 Variant="Warning" Effects="HorizontalScanlines, DiagonalStripes">
                    <BoxContainer Orientation="Vertical" Align="Center" SeparationOverride="0"
                                  HorizontalExpand="True" Margin="5 3">
                        <Label Name="EvacuationWarningLineOne" Access="Public"
                               Text="{Loc rmc-command-tablet-evacuation-warning-line-one}"
                               HorizontalExpand="True" Align="Center" FontColorOverride="#FFFFFF" />
                        <Label Name="EvacuationWarningLineTwo" Access="Public"
                               Text="{Loc rmc-command-tablet-evacuation-warning-line-two}"
                               HorizontalExpand="True" Align="Center" FontColorOverride="#FFFFFF" />
                    </BoxContainer>
                </crt:RMCCrtPanel>
                <!-- TODO RMC14: Add Distress Beacon only when RMC14 has a real distress/ERT system. -->
                <crt:RMCCrtActionButton Name="EvacuationButton" Access="Public"
                    Text="{Loc rmc-command-tablet-initiate-evacuation}" IconState="door_open"
                    Variant="Filled" ContentAlignment="Left" MinHeight="29" />
            </BoxContainer>
            <Control VerticalExpand="True" />
        </BoxContainer>
    </crt:RMCCrtThemeScope>
</controls:CommandTabletWindow>
