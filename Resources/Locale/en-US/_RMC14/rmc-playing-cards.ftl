# Card suits
rmc-playing-card-suit-spades = [color=SteelBlue]Spades[/color]
rmc-playing-card-suit-hearts = [color=Crimson]Hearts[/color]
rmc-playing-card-suit-diamonds = [color=Crimson]Diamonds[/color]
rmc-playing-card-suit-clubs = [color=SteelBlue]Clubs[/color]

# Card ranks
rmc-playing-card-rank-ace = [color=GoldenRod]Ace[/color]
rmc-playing-card-rank-jack = [color=GoldenRod]Jack[/color]
rmc-playing-card-rank-queen = [color=GoldenRod]Queen[/color]
rmc-playing-card-rank-king = [color=GoldenRod]King[/color]
rmc-playing-card-rank-ace-short = [color=GoldenRod]A[/color]
rmc-playing-card-rank-jack-short = [color=GoldenRod]J[/color]
rmc-playing-card-rank-queen-short = [color=GoldenRod]Q[/color]
rmc-playing-card-rank-king-short = [color=GoldenRod]K[/color]

# Card examination
rmc-playing-card-examine = [color=Tan][bold][italic]It's the [color=SandyBrown]{$rank}[/color] of {$suit}.[/italic][/bold][/color]
rmc-playing-card-examine-face-down = [color=Tan][italic]The card is face down.[/italic][/color]

# Card actions
rmc-playing-card-flip = You flip the card face {$direction}.
rmc-playing-card-draw = You draw the {$rank} of {$suit}.
rmc-playing-card-draw-hidden = You draw a card.
rmc-playing-card-draw-deck = You draw a card from the deck.
rmc-playing-card-add-to-hand = You add the card to the hand. ({$count} cards total)

# Deck examination
rmc-playing-card-deck-examine = [color=Tan][italic]Looks like [color=OliveDrab]{$count} cards[/color] in the box.[/italic][/color]
rmc-playing-card-deck-examine-verb = Controls
rmc-playing-card-deck-examine-verb-message = View deck controls.
rmc-playing-card-deck-examine-shuffle = [bold][color=SteelBlue]Alt[/color]+Activate [color=PeachPuff](E) (Z)[/color][/bold]
    — Shuffles the deck.
rmc-playing-card-deck-examine-draw = [bold]Activate [color=PeachPuff](E) (Z)[/color] or [color=PeachPuff](C)[/color] [color=SteelBlue]Interact[/color] other[/bold]
    — Draws a card.
rmc-playing-card-deck-examine-pickup = [bold][color=SteelBlue]Hold and click on empty ground[/color][/bold]
    — Picks up nearby cards.

# Deck actions
rmc-playing-card-deck-empty = The deck is empty!
rmc-playing-card-deck-full = The deck is full!
rmc-playing-card-deck-shuffle = You shuffle {THE($deck)}.
rmc-playing-card-added-to-deck = You add the card to the deck.
rmc-playing-card-added-cards-to-deck = You add {$count} cards to the deck.
rmc-playing-card-deck-pickup = You insert {$count} cards into the deck.
rmc-playing-card-draw-multiple = You draw {$count} cards.

# Hand of cards
rmc-playing-card-hand-name = Hand of cards
rmc-playing-card-stack-name = Stack of cards
rmc-playing-card-hand-examine = [color=Tan][italic]There are [color=OliveDrab]{$count} cards[/color] total.[/italic][/color]
rmc-playing-card-hand-examine-hidden = [color=Tan][italic]Looks like [color=OliveDrab]{$count} cards[/color], face down.[/italic][/color]
rmc-playing-card-hand-suit-group = - [bold][italic][color=SandyBrown]{$ranks}[/color] of {$suit}[/italic][/bold]

# Hand examination
rmc-playing-card-hand-examine-verb = Controls
rmc-playing-card-hand-examine-verb-message = View hand controls.
rmc-playing-card-hand-examine-face-down = [bold][color=SteelBlue]Face down[/color] [color=PeachPuff]E[/color] or [color=PeachPuff]Z[/color][/bold]
    — Draws a card from the top.
rmc-playing-card-hand-examine-face-up = [bold][color=SteelBlue]Face up[/color] [color=PeachPuff]E[/color] or [color=PeachPuff]Z[/color][/bold]
    — Opens hand to pick a specific card.
rmc-playing-card-hand-examine-flip = [bold][color=SteelBlue]Flip[/color] [color=PeachPuff]ALT + Activate[/color][/bold]
    — Flips the cards.

# Hand actions
rmc-playing-card-hand-flip = You flip the hand face {$direction}.
rmc-playing-card-hand-shuffle = You shuffle {THE($hand)}.
rmc-playing-card-hand-empty = The hand is empty!
rmc-playing-card-merge-hands = You merge the hands together. ({$count} cards total)

